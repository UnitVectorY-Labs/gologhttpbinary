name: gologhttpbinary
default_branch: main
config:
  description: "A lightweight HTTP server that logs HTTP requests, including the body encoded in base64, enabling logging of binary payloads."
  license: MIT
  language: go
  release: docker-go
  justfile: true
  status: active
  release_github: true
  codecov:
    enabled: true
  docs:
    enabled: false
